# Ghostty config — iTerm2-style keybindings + long-session settings
# Reload: Cmd+Shift+, (or restart Ghostty)

# --- iTerm2 look (exact port of "Default" profile) ---
# theme file: ~/.config/ghostty/themes/iterm2
# browse alternatives: ghostty +list-themes (interactive preview)
theme = iterm2
font-family = MesloLGS Nerd Font Mono
font-size = 13

# --- long Claude Code sessions ---
scrollback-limit = 100000
window-save-state = always
shell-integration-features = cursor,sudo,title
copy-on-select = clipboard
mouse-hide-while-typing = true

quit-after-last-window-closed = true
confirm-close-surface = false

# --- Quick Terminal (global dropdown, works from any app) ---
keybind = global:cmd+grave_accent=toggle_quick_terminal

# --- iTerm2-style splits ---
# iTerm2: Cmd+D = split vertically (new pane right), Cmd+Shift+D = split horizontally (new pane below)
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

# pane navigation (iTerm2: Cmd+Opt+Arrows)
keybind = cmd+opt+left=goto_split:left
keybind = cmd+opt+right=goto_split:right
keybind = cmd+opt+up=goto_split:up
keybind = cmd+opt+down=goto_split:down

# cycle panes (iTerm2: Cmd+] / Cmd+[)
keybind = cmd+right_bracket=goto_split:next
keybind = cmd+left_bracket=goto_split:previous

# maximize/restore pane (iTerm2: Cmd+Shift+Enter)
keybind = cmd+shift+enter=toggle_split_zoom

# Already iTerm2-compatible Ghostty defaults (no config needed):
# Cmd+T new tab, Cmd+W close pane/tab, Cmd+N new window,
# Cmd+1..9 jump to tab, Cmd+Shift+[ / ] prev/next tab,
# Cmd+K clear screen, Cmd+Enter fullscreen, Cmd+F find
